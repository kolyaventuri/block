{
  "compilerOptions": {
    "noImplicitAny": true,
    "removeComments": true,
    "outDir": "./dist" ,
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "target": "es2019",
    "module": "Node16",
    "moduleResolution": "node16",
    "types": ["react"],
    "jsx": "react",
    "baseUrl": ".",
    "esModuleInterop": true
  },
  "exclude": ["node_modules", "test/**/*"],
  "include": ["src"] 
}
