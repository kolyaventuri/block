{
  "name": "slackblock",
  "version": "0.4.0",
  "description": "React-based Slack message renderer",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.12.0",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./block": {
      "types": "./lib/block.d.ts",
      "default": "./lib/block.js"
    }
  },
  "files": [
    "lib",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "npm-run-all test:*",
    "test:tsc": "tsc -p ./src -p ./test --noEmit",
    "test:lint": "xo",
    "test:unit": "ava",
    "build": "npm-run-all build:*",
    "build:package": "tsc -p .",
    "prepublish": "npm-run-all test:* build:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kolyaventuri/block.git"
  },
  "keywords": [
    "react",
    "slack",
    "message",
    "bot"
  ],
  "author": "Kolya Venturi <me@kolya.co>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kolyaventuri/block/issues"
  },
  "homepage": "https://github.com/kolyaventuri/block#readme",
  "devDependencies": {
    "@types/node": "25.0.10",
    "@types/proxyquire": "^1.3.28",
    "@types/react": "^16.9.13",
    "@types/sinon": "^7.5.1",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "ava": "^2.4.0",
    "coveralls": "^3.0.9",
    "enzyme": "^3.10.0",
    "enzyme-adapter-react-16": "^1.15.1",
    "eslint": "^9.39.2",
    "eslint-config-xo": "^0.49.0",
    "eslint-config-xo-react": "^0.29.0",
    "eslint-config-xo-typescript": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "npm-run-all": "^4.1.5",
    "nyc": "^14.1.1",
    "pre-commit": "^1.2.2",
    "proxyquire": "^2.1.3",
    "sinon": "^7.5.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "xo": "^1.2.3"
  },
  "pre-commit": [
    "test:tsc",
    "test:lint"
  ],
  "ava": {
    "compileEnhancements": false,
    "extensions": [
      "ts",
      "tsx"
    ],
    "files": [
      "test/**/*.test.ts?(x)"
    ],
    "helpers": [
      "test/helpers/**/*.ts"
    ],
    "require": [
      "ts-node/register",
      "tsconfig-paths/register"
    ]
  },
  "dependencies": {
    "react": "^16.12.0"
  }
}
