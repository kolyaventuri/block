{
  "name": "slackblock",
  "version": "1.1.0",
  "description": "JSX-based Slack message renderer",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "block": [
        "dist/block.d.ts"
      ],
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./block": {
      "types": "./dist/block.d.ts",
      "import": "./dist/block.mjs",
      "require": "./dist/block.cjs",
      "default": "./dist/block.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepare": "husky install",
    "test": "pnpm run test:tsc && pnpm run test:lint && pnpm run test:knip && pnpm run test:unit",
    "test:tsc": "tsc -p tsconfig.json --noEmit && tsc -p test/tsconfig.json --noEmit",
    "test:lint": "xo --fix",
    "test:knip": "knip",
    "test:unit": "vitest run",
    "prebuild": "pnpm run clean",
    "clean": "rimraf ./dist",
    "build": "tsup",
    "prepublishOnly": "pnpm run test && pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kolyaventuri/block.git"
  },
  "keywords": [
    "slack",
    "message",
    "bot"
  ],
  "author": "Kolya Venturi <me@kolya.co>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kolyaventuri/block/issues"
  },
  "homepage": "https://github.com/kolyaventuri/block#readme",
  "devDependencies": {
    "@types/node": "25.0.10",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-config-xo": "^0.49.0",
    "eslint-config-xo-typescript": "^9.0.0",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.2.7",
    "rimraf": "^6.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "xo": "^1.2.3"
  },
  "dependencies": {
    "@slack/types": "^2.19.0"
  },
  "pnpm": {
    "overrides": {
      "@eslint/plugin-kit": "^0.3.4",
      "minimatch": "^10.2.3",
      "rollup": "^4.59.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "xo"
    ]
  }
}
